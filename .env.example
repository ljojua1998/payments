# ─────────────────────────────────────────────────────────────
# Supabase — Database, Auth, Storage
# მნიშვნელობები: Dashboard → Project Settings → API Keys
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# secret key მხოლოდ სერვერზე გამოიყენება (OTP ვერიფიკაცია, მომხმარებლის
# შექმნა, დოკუმენტის/ასისტენტის route-ები). კლიენტში არასდროს ხვდება.
SUPABASE_SECRET_KEY=your-secret-key

# ─────────────────────────────────────────────────────────────
# ubill.dev — SMS OTP პროვაიდერი (რეგისტრაცია / პაროლის აღდგენა)
# ─────────────────────────────────────────────────────────────
SMS_PROVIDER_API_KEY=your-ubill-api-key
SMS_BRAND_ID=your-ubill-brand-id

# ─────────────────────────────────────────────────────────────
# Groq — AI (PDF ანალიზი + Payments AI ასისტენტი). უფასო tier.
# გასაღები: https://console.groq.com
# GROQ_MODEL არასავალდებულოა (default: llama-3.3-70b-versatile)
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
# GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────────────────────────
# მხოლოდ ლოკალურად, კორპორატიული proxy-ის უკან (TLS certificate
# chain-ის შემცვლელი). Vercel-ზე / პროდაქშენში არ დაამატოთ.
# NODE_TLS_REJECT_UNAUTHORIZED=0
# ─────────────────────────────────────────────────────────────
